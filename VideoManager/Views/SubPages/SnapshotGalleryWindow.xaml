<Window x:Class="VideoManager.Views.SubPages.SnapshotGalleryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="截图列表"
        Height="560"
        Width="860"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding HeaderText}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <ListView Grid.Row="1" ItemsSource="{Binding Records}">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Width="190" Margin="6" BorderBrush="#33000000" BorderThickness="1" CornerRadius="4" Padding="6">
                        <StackPanel>
                            <Border Width="176" Height="110" Background="#11000000">
                                <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                            </Border>
                            <TextBlock Margin="0,6,0,0" Text="{Binding CaptureTimeText}" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,2,0,0" Text="{Binding FileName}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
