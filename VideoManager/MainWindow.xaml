<Window x:Class="VideoManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VideoManager"
        mc:Ignorable="d"
        Icon="/Assets/Ico/play_market_icon.ico"
        WindowStartupLocation="CenterScreen"
        Title="VideoManager"
        Height="900"
        Width="1600">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,15,0,0">
                <TextBlock Text="VideoManager" FontSize="22" FontWeight="Bold" 
                           Foreground="White" Margin="20,0,20,20" TextAlignment="Center"/>

                <Button x:Name="HomeButton" Content="首页" Height="50" Margin="10,5" 
                        Background="Transparent" Foreground="White" FontSize="16"
                        BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="VideoOprButton" Content="视频查看" Height="50" Margin="10,5" 
                        Background="Transparent" Foreground="White" FontSize="16"
                        BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
                <Button x:Name="aboutButton" Content="关于" Height="50" Margin="10,5" 
                        Background="Transparent" Foreground="White" FontSize="16"
                        BorderThickness="0" HorizontalContentAlignment="Left" Padding="20,0,0,0"/>
            </StackPanel>
        </Border>

    </Grid>
</Window>
